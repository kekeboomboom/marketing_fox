{
  "name": "marketing_fox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal marketing agent for X, XiaoHongShu, and WeChat Official Accounts.",
  "scripts": {
    "dev": "tsx src/ts/index.ts",
    "api": "tsx src/ts/api-server.ts",
    "web:dev": "next dev --hostname 127.0.0.1 --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "xhs:login": "tsx src/ts/index.ts xhs-login",
    "xhs:check": "tsx src/ts/index.ts xhs-check",
    "check": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test:ts": "node --import tsx --test tests/ts/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
