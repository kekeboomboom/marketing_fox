# Shared test environment identity
COMPOSE_PROJECT_NAME=marketing_fox-test
MARKETING_FOX_PUBLIC_DOMAIN=marketingfox-test.keboom.ai
MARKETING_FOX_APP_DIR=/srv/marketing_fox-test
MARKETING_FOX_API_IMAGE=ghcr.io/kekeboomboom/marketing-fox-api:test
MARKETING_FOX_WEB_IMAGE=ghcr.io/kekeboomboom/marketing-fox-web:test

# Shared host allocations
MARKETING_FOX_FRONTEND_PORT=20000
MARKETING_FOX_BACKEND_PORT=20001
MARKETING_FOX_RUNTIME_DIR=./runtime

# API runtime
MARKETING_FOX_API_HOST=0.0.0.0
MARKETING_FOX_API_PORT=3001
MARKETING_FOX_API_TOKEN=change-me
MARKETING_FOX_OPERATOR_PASSWORD=change-me
MARKETING_FOX_OPERATOR_COOKIE_NAME=marketing_fox_operator_session
MARKETING_FOX_DATA_DIR=/data/marketing_fox/service-data
MARKETING_FOX_ARTIFACTS_DIR=/data/marketing_fox/artifacts
MARKETING_FOX_WEB_API_BASE_URL=http://api:3001

# Xiaohongshu browser runtime
XHS_PROFILE_DIR=/data/marketing_fox/xhs-profile
XHS_BROWSER_CACHE_DIR=/ms-playwright
XHS_HEADLESS=false
XHS_LOGIN_TIMEOUT_MS=300000
XHS_LOCALE=zh-CN
XHS_TIMEZONE=Asia/Shanghai
XHS_BROWSER_CHANNEL=
XHS_BROWSER_EXECUTABLE_PATH=
XHS_BROWSER_ARGS=
